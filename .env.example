APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL_RETRIEVAL=gpt-5.4
OPENAI_MODEL_REVIEW=gpt-5-mini
OPENAI_MODEL_CRITIC=gpt-5.4
OPENAI_MODEL_PLANNER=gpt-5.4

